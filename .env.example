DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=90

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
RETRIEVAL_MODE=vector
VECTOR_STORE_BACKEND=chroma
MODEL_CACHE_DIR=E:\for-LLM\AUXI\Tarot_Persona_Agent\models
CHROMA_DIR=data\indexes\chroma
BUILD_CHROMA=1

PDF_OCR_ENABLED=1
PDF_OCR_DPI=180
PDF_OCR_MIN_CHARS=40

# Optional: OpenAI-compatible vision model for screenshot case extraction.
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
CASE_EXTRACT_MODEL=deepseek-chat
